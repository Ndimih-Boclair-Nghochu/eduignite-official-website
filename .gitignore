studio-main/.babelrc

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
studio-main/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Python / Django ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.venv
venv/
env/
.env/
backend/staticfiles/
backend/media/
backend/logs/
*.log

# ─── Docker ───────────────────────────────────────────────────────────────────
