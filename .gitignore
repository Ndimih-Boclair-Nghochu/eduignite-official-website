docker-compose.override.yml

# ─── SSL certificates ─────────────────────────────────────────────────────────
nginx/ssl/*.pem
nginx/ssl/*.crt
nginx/ssl/*.key
# Keep the .gitkeep placeholder
!nginx/ssl/.gitkeep

# ─── Editors & OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
